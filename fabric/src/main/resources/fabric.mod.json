{
  "schemaVersion": 1,
  "id": "${mod_id}",
  "version": "${version}",
  "name": "${mod_name}",
  "description": "${mod_description}",
  "license": "${mod_license}",
  "icon": "${mod_icon_path}",
  "authors": [
    "${mod_authors}"
  ],
  "environment": "*",
  "entrypoints": {
    "main": [
      "me.johardt.CobblemonCharged"
    ]
  },
  "mixins": [
    "cobblemoncharged.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": ">=${fabric_api_version}",
    "minecraft": "${minecraft_version}",
    "java": "21",
    "cobblemon": "${cobblemon_version_predicate}"
  }
}
